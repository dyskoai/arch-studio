# Production/deployment environment example for Arch Studio.
# Copy/export these values on the remote deployment machine as needed.

# Model config
REFINER_MODEL=gemini-2.5-flash
ROUTER_MODEL=gemini-2.5-flash
ARCHITECT_MODEL=gemini-2.5-pro
MODEL_LOCATION=global

# Vertex AI / Agent Engine
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=caramel-binder-466205-q9
GOOGLE_CLOUD_LOCATION=global
GCP_PROJECT=caramel-binder-466205-q9
GCP_LOCATION=us-central1
AGENT_ENGINE_RESOURCE=projects/797664949634/locations/us-central1/reasoningEngines/8644000327516815360

# Cloud Run runtime
USE_AGENT_ENGINE=true
ENV=production
BACKEND_SERVICE_ACCOUNT=797664949634-compute@developer.gserviceaccount.com

# Domains / CORS
FRONTEND_DOMAIN=archstudio.thedysko.ai
API_DOMAIN=api-archstudio.thedysko.ai
ALLOWED_ORIGINS=https://archstudio.thedysko.ai,https://intentiv-frontend-p63c3k77ea-uc.a.run.app

# Optional local/API-key mode. Leave empty in production Vertex AI mode.
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Server config
RATE_LIMIT_PER_MINUTE=10
