# ─── Model strings ────────────────────────────────────────────────────────────
# Change to any ADK-compatible model string — no code change needed.
#
# Native Gemini:  gemini-3.1-pro-preview
# Via LiteLLM:    litellm/anthropic/claude-sonnet-4-20250514
#                 litellm/openai/gpt-4o
#                 litellm/<provider>/<model>
#
REFINER_MODEL=gemini-2.5-flash-lite
ROUTER_MODEL=gemini-2.5-flash-lite
ARCHITECT_MODEL=gemini-2.5-pro
MODEL_LOCATION=global

# ─── API keys — set whichever your model strings require ──────────────────────
GOOGLE_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=                        # set if using litellm/anthropic/...
OPENAI_API_KEY=                           # set if using litellm/openai/...

# ─── Server config ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://intentiv.ai
RATE_LIMIT_PER_MINUTE=10
ENV=development
